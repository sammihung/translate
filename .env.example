# ASR Model (local inference)
# Options: Qwen/Qwen3-ASR-1.7B, Qwen/Qwen3-ASR-0.6B, Qwen/Qwen3-ASR-1.7B-8bit
ASR_MODEL=Qwen/Qwen3-ASR-1.7B

# Translation (LM Studio API)
TRANSLATE_MODEL=qwen/qwen3.5-9b
TRANSLATE_API_URL=http://localhost:1234/v1
# TRANSLATE_API_KEY=

# Audio source: mic, system, per-app
AUDIO_SOURCE=mic
TARGET_APP=

# VAD (Silero)
VAD_SILENCE_DURATION=0.8
VAD_SPEECH_DURATION=2.0
VAD_MAX_CHUNK_DURATION=4.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/qwen_asr.log