# ASR
ASR_MODEL=qwen3-asr-1.7b
ASR_API_URL=http://localhost:1234/v1
# ASR_API_KEY=

# Translation
TRANSLATE_MODEL=qwen3.5-9b
TRANSLATE_API_URL=http://localhost:1234/v1
# TRANSLATE_API_KEY=

# Audio source: mic, system, per-app
AUDIO_SOURCE=mic
TARGET_APP=

# VAD
VAD_RMS_THRESHOLD=150.0
VAD_SILENCE_DURATION=1.5
VAD_MAX_CHUNK_DURATION=8.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/qwen_asr.log