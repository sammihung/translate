# ==========================================
# Device Configuration
# ==========================================
# Choose default device: cpu or cuda
# App will use this device by default
DEFAULT_DEVICE=cpu

# User can override device preference
# ASR_DEVICE=cpu
# ASR_DEVICE=cuda

# ==========================================
# Worker URLs (for Docker deployment)
# ==========================================
# These are set automatically in Docker
# Override for local development
CPU_WORKER_URL=http://localhost:8001
GPU_WORKER_URL=http://localhost:8002

# ==========================================
# Ollama Configuration
# ==========================================
OLLAMA_BASE_URL=http://localhost:11434
TRANSLATION_MODEL=translategemma:4b-it-q4_K_M

# ==========================================
# ASR Model Configuration
# ==========================================
# Model to use for speech recognition
ASR_MODEL=Qwen/Qwen3-ASR-1.7B

# Performance mode: fast, balanced, full
PERFORMANCE_MODE=balanced

# ==========================================
# Audio Configuration
# ==========================================
# VAD (Voice Activity Detection) settings
VAD_RMS_THRESHOLD=175
VAD_SILENCE_DURATION=1.5
VAD_MAX_AUDIO_LENGTH=8.0

# Sample rate
SAMPLE_RATE=16000

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=INFO
LOG_FILE=logs/qwen_asr.log
