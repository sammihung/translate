# Qwen ASR Translate - 環境變數範本
# 複製此檔案為 .env 並填入實際值

# =============================================================================
# AI 模型配置
# =============================================================================

# ASR 模型設定
ASR_MODEL_NAME=Qwen/Qwen3-ASR-1.7B
ASR_DEVICE=cuda
ASR_USE_INT8=true

# 翻譯模型設定
TRANSLATE_MODEL_NAME=translategemma:4b-it-q4_K_M
OLLAMA_API_URL=http://localhost:11434
OLLAMA_TIMEOUT=60

# =============================================================================
# VAD (語音活動偵測) 配置
# =============================================================================

VAD_RMS_THRESHOLD=150.0
VAD_SILENCE_DURATION=1.5
VAD_MAX_CHUNK_DURATION=8.0

# =============================================================================
# 效能配置
# =============================================================================

# 效能模式：fast, balanced, full
PERFORMANCE_MODE=balanced

# Thread Pool 設定
TRANSLATE_POOL_MAX_WORKERS=3

# =============================================================================
# HuggingFace 配置 (用於 Speaker Diarization)
# =============================================================================

HF_TOKEN=your_huggingface_token_here
USE_SPEAKER_DIARIZATION=false

# =============================================================================
# 日誌配置
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/qwen_asr.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# =============================================================================
# UI 配置
# =============================================================================

UI_THEME=dark
UI_ACCENT_COLOR=#3b82f6
UI_LANGUAGE=zh_TW
