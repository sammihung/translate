# GPU Worker - ASR inference with CUDA support
# Uses NVIDIA CUDA base image with GPU PyTorch
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

WORKDIR /app

# Install Python and dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3-pip \
    portaudio19-dev \
    ffmpeg \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && useradd -m -u 1000 appuser

# Upgrade pip and install uv
RUN pip3 install --upgrade pip uv

# Copy dependency files
COPY pyproject.toml requirements.txt ./

# Install GPU torch first
RUN uv pip install --system --no-cache-dir \
    torch \
    torchaudio \
    --index-url https://download.pytorch.org/whl/cu121

# Install other dependencies
RUN uv pip install --system --no-cache-dir -r requirements.txt

# Install FastAPI for worker API
RUN pip3 install --no-cache-dir fastapi uvicorn httpx

# Copy application code
COPY --chown=appuser:appuser src/ ./src/
COPY --chown=appuser:appuser config.ini ./

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    TRANSFORMERS_VERBOSITY=error \
    CUDA_VISIBLE_DEVICES=0 \
    APP_ROLE=worker \
    WORKER_DEVICE=cuda

# Switch to non-root user
USER appuser

# Create logs directory
RUN mkdir -p /app/logs

EXPOSE 8001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

CMD ["python3", "-m", "uvicorn", "src.qwen_asr_app.worker:app", "--host", "0.0.0.0", "--port", "8001"]
