# CPU Worker - ASR inference on CPU only
# Uses CPU-only PyTorch for smaller image size
FROM python:3.11-slim

WORKDIR /app

# Install build and runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    portaudio19-dev \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/* \
    && useradd -m -u 1000 appuser

# Upgrade pip and install uv
RUN pip install --upgrade pip uv

# Copy dependency files
COPY pyproject.toml requirements.txt ./

# Install CPU-only torch first (smaller package)
RUN uv pip install --system --no-cache-dir \
    torch \
    torchaudio \
    --index-url https://download.pytorch.org/whl/cpu

# Install other dependencies
RUN uv pip install --system --no-cache-dir -r requirements.txt

# Install FastAPI for worker API
RUN pip install --no-cache-dir fastapi uvicorn httpx

# Copy application code
COPY --chown=appuser:appuser src/ ./src/
COPY --chown=appuser:appuser config.ini ./

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    TRANSFORMERS_VERBOSITY=error \
    CUDA_VISIBLE_DEVICES="" \
    APP_ROLE=worker \
    WORKER_DEVICE=cpu

# Switch to non-root user
USER appuser

# Create logs directory
RUN mkdir -p /app/logs

EXPOSE 8001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

CMD ["python", "-m", "uvicorn", "src.qwen_asr_app.worker:app", "--host", "0.0.0.0", "--port", "8001"]
